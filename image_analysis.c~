def update_x_xx(int *x, int *xx, uint16 *im, int s0, int s1){
  int i0,i1;
  int o0;
  int t0;

  for(i0=0;i0<s0;i0++){
    o0 = i0*s1;
    for(i1=0;i1<s1;i1++){
      t0 = (int)im[o0+i1];
      x[o0+i1] += t0;
      xx[o0+i1] += t0*t0;
    }
  }
}
