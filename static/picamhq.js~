function statusUpdate(json){
    let sigColor = chartColors[json['signal quality']];
    
    document.getElementById('offset').innerHTML = json['offset'].toFixed(4);

    document.getElementById('sum').innerHTML = json['sum'].toFixed(1);
    document.getElementById('sum').style.color = sigColor;
    
    document.getElementById('contrast').value = json['contrast'];
    document.getElementById('contrast value').innerHTML = json['contrast'].toFixed(0);
    
    document.getElementById('laser power').innerHTML = json['laser power'].toFixed(0);
    
    document.getElementById('laser set point').value = json['laser set point'];
    document.getElementById('laser set point value').innerHTML = json['laser set point'].toFixed(0);

    if (json['lock target'] === ""){
	document.getElementById('lock target').innerHTML = "";
    }
    else{
	document.getElementById('lock target').innerHTML = json['lock target'].toFixed(3);
    }
    
    document.getElementById('mode').innerHTML = json['mode'].toLocaleString("en-IN");
    if (json['mode'] == 'locked'){
	document.getElementById('mode').style.color = chartColors[json['lock quality']];
    }
    else{
	document.getElementById('mode').style.color = "black";
    }
    updateLockButtonText(json['mode']);
    document.getElementById("raw corrected").checked = !json['offset unwrapped'];
    updateUiLockout(json['ui lockout']);

    document.getElementById('z position').innerHTML = json['z position'].toFixed(3);

    /* Update chart. */
    addOffsetToChart(json['offset'], sigColor);
}

