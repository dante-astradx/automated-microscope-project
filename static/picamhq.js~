function makeChart() {
    let colors = [];
    let data = [];
    for (let i = -20; i <= 0; i++){
	colors.push('green')
	data.push({x : i, y : 0})
    }
    
    chart = new Chart(
	document.getElementById('acquisitions'),
	{
	    type: 'line',
	    data: {
		labels: data.map(row => row.x),
		datasets: [
		    {
			label: '',
			data: data.map(row => row.y),
			borderColor: 'rgb(210, 210, 210)',
			pointBackgroundColor: 'white',
			pointBorderColor: colors
		    }
		]
	    },
	    options: {
		plugins: {
		    legend: {
			display: false
		    },
		    tooltip: {
			enabled: false
		    }
		},
		animation: {
		    duration: 0
		},
		scales: {
		    x: {
			ticks: {
			    display: false
			}
		    }
		}
	    }
	}
    );
}

