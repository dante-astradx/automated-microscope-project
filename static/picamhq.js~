
var chart = null;
var chartColors = ["red", "yellow", "green"];
var curLockout = null;
var curMode = "na";

var chartTimeout = setTimeout(makeChart, 1);
var imageInterval = setInterval(getImage, 200);
var statusInterval = setInterval(getStatus, 100);


function addOffsetToChart(offset, color){
    let colors = chart.data.datasets[0].pointBorderColor;
    let data = chart.data.datasets[0].data;
    for (let i = 0; i < (data.length - 1); i++) {
	colors[i] = colors[i+1];
	data[i] = data[i+1];
    }
    colors[(data.length-1)] = color
    data[(data.length-1)] = offset
    chart.update();
}

function getImage() {
    let params = new URLSearchParams({cmd: 'getImage'})
    fetch('/axicon/uiCommand?' + params.toString())
	.then(response => response.json())  
	.then(json => {
	    var image = document.getElementById('image');
	    image.src = 'data:image/jpeg;base64,'+json['image'];
	    var unwrapped = document.getElementById('unwrapped');
	    unwrapped.src = 'data:image/jpeg;base64,'+json['unwrapped'];	    
	})
}

function getStatus() {
    let params = new URLSearchParams({cmd: 'getStatus'})
    fetch('/axicon/uiCommand?' + params.toString())    
	.then(response => response.json())  
	.then(json => {
	    statusUpdate(json);
	})
}

