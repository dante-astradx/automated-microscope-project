function updateLockButtonText(mode){
    if (mode == curMode){
	return;
    }

    curMode = mode;
    if (mode == 'none'){
	document.getElementById('lock button').textContent = 'Lock';
    }
    else if (mode == 'locked'){
	document.getElementById('lock button').textContent = 'Unlock';
    }
}

function updateUiLockout(lockout){
    if (curLockout == lockout){
	return;
    }

    curLockout = lockout;

    // Enable/disable buttons and laser power slider.
    let controls = ['mcu button', 'mcd button', 'mcl button', 'mcr button', 'ju button',
		    'jd button', 'lock button', 'rezero button', 'laser set point'];
    for (let i = 0; i < controls.length; i++) {
	document.getElementById(controls[i]).disabled = lockout;
    }
}
